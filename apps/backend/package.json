{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "npm run lint && npm run check-types",
    "lint": "eslint src",
    "check-types": "node --check src/server.js && node --check src/config/env.js && node --check src/config/db.js && node --check src/config/cron.js && node --check src/db/schema.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "description": "Backend API workspace for Recipe App.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "cron": "^4.3.3",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.44.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
